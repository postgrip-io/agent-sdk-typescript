# Copy to .env at the repository root before running examples.
# Agent token from Settings > Organization > Agent tokens.
POSTGRIP_AGENT_TOKEN=

# Optional for local/self-hosted development. Omit for PostGrip Cloud.
# POSTGRIP_AGENTORCHESTRATOR_URL=http://127.0.0.1:4100

# Host-agent pool for the workflow.runtime submitter.
SDK_EXAMPLE_RUNTIME_QUEUE=default

# Long-running workflow demo metadata.
SDK_EXAMPLE_RUN_LABEL=sdk-ui-demo-ts
SDK_EXAMPLE_WORKFLOW_RUNS=2
SDK_EXAMPLE_STEPS=5
SDK_EXAMPLE_STEP_SLEEP_SECONDS=13
